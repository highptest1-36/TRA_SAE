huggingface_tokenizers_cache/
unsloth_compiled_cache/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── LaTeX build artifacts ──────────────────────────────────────────────────────
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/missfont.log

